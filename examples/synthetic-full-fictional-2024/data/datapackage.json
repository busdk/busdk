{
  "busdk": {
    "accounting_entity": {
      "base_currency": "EUR",
      "fiscal_year_start": "2024-01-01",
      "fiscal_year_end": "2024-12-31",
      "vat_registered": true,
      "vat_reporting_period": "monthly",
      "vat_timing": "performance",
      "vat_default_source": "invoice",
      "vat_default_basis": "accrual",
      "reporting_context": {
        "fi": {
          "taxonomy": "fi-kpa",
          "taxonomy_version": "2026-03",
          "income_statement_scheme": "by_nature",
          "language": "fi",
          "presentation_currency": "EUR",
          "presentation_unit": "EUR",
          "reporting_scope": "entity"
        }
      },
      "reporting_profile": {
        "fi_statutory": {
          "reporting_standard": "fi-kpa",
          "language": "fi",
          "income_statement_scheme": "by_nature",
          "comparatives": true,
          "presentation_currency": "EUR",
          "presentation_unit": "EUR",
          "prepared_under_pma": false,
          "signature": {}
        }
      },
      "id_generation": {
        "types": {
          "attachment_id": {
            "strategy": "uuid"
          },
          "bank_import_id": {
            "strategy": "uuid"
          },
          "bank_txn_id": {
            "strategy": "template",
            "template": "{import_id}-{row_index}"
          },
          "entry_id": {
            "strategy": "template",
            "template": "{transaction_id}-e{entry_sequence}"
          },
          "inventory_movement_id": {
            "strategy": "uuid"
          },
          "invoice_id": {
            "strategy": "uuid"
          },
          "invoice_number": {
            "strategy": "sequence",
            "template": "INV-{yyyy}-{inc}",
            "scope": "yearly",
            "ranges": [
              {
                "start": 1,
                "end": 999999,
                "width": 6
              }
            ]
          },
          "link_id": {
            "strategy": "uuid"
          },
          "loan_event_id": {
            "strategy": "template",
            "template": "EV-{loan_id}-{yyyyMMdd}-{inc}",
            "series": [
              {
                "name": "loan-default",
                "match": {
                  "module": "bus-loans"
                },
                "strategy": "sequence",
                "template": "EV-{loan_id}-{yyyyMMdd}-{inc}",
                "scope": "daily",
                "ranges": [
                  {
                    "start": 1,
                    "end": 9999,
                    "width": 4
                  }
                ]
              }
            ]
          },
          "payment_id": {
            "strategy": "uuid"
          },
          "payrun_id": {
            "strategy": "uuid"
          },
          "transaction_id": {
            "strategy": "uuid"
          },
          "voucher_id": {
            "strategy": "sequence",
            "template": "V-{yyyy}-{inc}",
            "scope": "yearly",
            "ranges": [
              {
                "start": 1,
                "end": 999999,
                "width": 6
              }
            ]
          }
        }
      }
    }
  },
  "profile": "tabular-data-package",
  "resources": [
    {
      "name": "account-groups",
      "path": "account-groups.csv",
      "schema": {
        "path": "account-groups.schema.json"
      }
    },
    {
      "name": "accounts",
      "path": "accounts.csv",
      "schema": {
        "path": "accounts.schema.json"
      }
    },
    {
      "name": "bank-imports",
