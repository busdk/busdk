# Non-secret defaults for the source-checkout local Bus cloud platform stack.
# Copy to .env and edit locally when needed. Docker Compose reads .env
# automatically from the superproject root.

LOCAL_AI_PLATFORM_PORT=8080
LOCAL_AI_PLATFORM_POSTGRES_PORT=15432
LOCAL_AI_PLATFORM_SMTP_PORT=1025
LOCAL_AI_PLATFORM_MAILHOG_PORT=8025

LOCAL_AI_PLATFORM_POSTGRES_DB=bus_local
LOCAL_AI_PLATFORM_POSTGRES_USER=bus
LOCAL_AI_PLATFORM_POSTGRES_PASSWORD=bus

BUS_LOCAL_JWT_SECRET=not-a-secret-local-development-hs256-key
BUS_LOCAL_ACCOUNT_ID=00000000-0000-4000-8000-000000000001
BUS_AUTH_INTERNAL_SHARED_KEY=not-a-secret-local-development-internal-key
BUS_AUTH_SMTP_FROM=bus-auth@example.invalid

BUS_LOCAL_BILLING_PROVIDER_BACKEND=local
BUS_LLM_BILLING_BACKEND=none
BUS_CODEX_PROVIDER=codex
BUS_CODEX_WORKDIR=/workspace
BUS_CODEX_MODEL=auto
BUS_CODEX_COMMAND=codex
# BUS_CODEX_HOME defaults to $HOME/.codex when unset.

BUS_STRIPE_WEBHOOK_SECRET=whsec_local_not_secret
BUS_STRIPE_SECRET_KEY=
BUS_STRIPE_DEFAULT_PRICE_ID=

DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_CONTAINER_CODEX_IMAGE=alpine:3.20
