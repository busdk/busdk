{
  "default": "localhost",
  "remotes": [
    {
      "id": "localhost",
      "kind": "compose",
      "url": "http://localhost:8081",
      "compose_file": "compose.yaml",
      "compose_project": "bus-local-ai-platform"
    },
    {
      "id": "dev-hg",
      "kind": "ssh-docker",
      "compose_file": "compose.yaml",
      "ssh_target": "coding-agent@dev.hg.fi",
      "ssh_host": "dev.hg.fi",
      "ssh_user": "coding-agent",
      "ssh_port": 22,
      "remote_workdir": "/home/coding-agent/coding-agent/git/busdk/busdk",
      "controller_events_url": "http://127.0.0.1:8081",
      "worker_events_url": "http://127.0.0.1:8081/local/v1",
      "credential_source": {
        "kind": "ssh-issued-token",
        "ref": "bus operator-token --format json --local issue events-relay",
        "lifetime_seconds": 86400,
        "refresh_before_seconds": 3600
      },
      "events_relay": {
        "owner_environment_id": "local-dev",
        "route_pair_id": "local_dev_hg_events"
      },
      "worker_defaults": {
        "agent_backend": "codex-appserver",
        "container_profile": "codex",
        "model": "gpt-5.4",
        "reasoning_effort": "high",
        "auth_mode": "chatgpt-subscription"
      },
      "worker_profiles": {
        "codex-spark": {
          "agent_backend": "codex-appserver",
          "container_profile": "codex",
          "model": "gpt-5.3-codex-spark",
          "reasoning_effort": "high",
          "auth_mode": "chatgpt-subscription",
          "credential_source": {
            "kind": "os-credential-label",
            "ref": "codex-chatgpt-subscription"
          }
        }
      },
      "worker_environment": {
        "path_additions": [
          "/home/coding-agent/coding-agent/.nvm/versions/node/v22.19.0/bin"
        ],
        "tool_paths": {
          "codex": "/home/coding-agent/coding-agent/.nvm/versions/node/v22.19.0/bin/codex",
          "node": "/home/coding-agent/coding-agent/.nvm/versions/node/v22.19.0/bin/node"
        }
      }
    },
    {
      "id": "ai-hg-h100",
      "kind": "ssh-docker",
      "compose_file": "compose.yaml",
      "ssh_target": "dev@ai.hg.fi",
      "ssh_host": "ai.hg.fi",
      "ssh_user": "dev",
      "ssh_port": 22,
      "remote_workdir": "/home/dev/workspace/busdk/busdk",
      "controller_events_url": "http://127.0.0.1:8081",
      "worker_events_url": "http://bus-events:8081",
      "credential_source": {
        "kind": "token-file",
        "ref": "/home/dev/.config/bus/auth/api-token"
      },
      "worker_defaults": {
        "agent_backend": "codex-appserver",
        "container_profile": "codex",
        "model": "gpt-oss:120b",
        "reasoning_effort": "high",
        "auth_mode": "local-provider"
      }
    }
  ],
  "environments": [
    {
      "id": "env_h100_ai",
      "name": "h100",
      "display_name": "H100 Local",
      "remote_id": "ai-hg-h100",
      "local_environment_id": "local-events",
      "sync_target_ids": [
        "env_h100_ai"
      ],
      "sync_state": {
        "env_h100_ai": "pending"
      },
      "worker_styles": [
        "ssh-docker"
      ],
      "worker_defaults": {
        "agent_backend": "codex-appserver",
        "container_profile": "codex",
        "model": "gpt-oss:120b",
        "reasoning_effort": "high",
        "auth_mode": "local-provider"
      }
    },
    {
      "id": "env-dev-hg-codex",
      "name": "dev-hg",
      "display_name": "dev.hg.fi Codex",
      "remote_id": "dev-hg",
      "default_worker_profile": "codex-spark",
      "worker_styles": [
        "ssh-docker"
      ],
      "worker_defaults": {
        "reasoning_effort": "high"
      }
    }
  ]
}
