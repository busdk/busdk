          "codex": "/home/coding-agent/.local/bin/codex",
          "node": "/usr/local/bin/node"
        }
      }
    }
  ],
  "environments": [
    {
      "id": "ai.hg.fi",
      "name": "ai.hg.fi",
      "display_name": "ai.hg.fi",
      "remote_id": "ai.hg.fi",
